{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:base"],
  "dependencyDashboardApproval": true,
  "packageRules": [
    {
      "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
      "automerge": true
    },
    {
      "matchFileNames": ["mitoma-org/frontend/**"],
      "groupName": "mitoma-org frontend"
    },
    {
      "matchFileNames": ["mitoma-org/backend/**"],
      "groupName": "mitoma-org backend"
    },
    {
      "matchFileNames": ["rust/**"],
      "groupName": "rust workspace"
    }
  ],
  "regexManagers": [
    {
      "fileMatch": ["Dockerfile"],
      "matchStrings": ["ARG SVER_VERSION=\"(?<currentValue>.*?)\"\n"],
      "depNameTemplate": "mitoma/sver",
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "semver"
    }
  ]
}
